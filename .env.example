# ═══════════════════════════════════════════════════════════════
# Live Whiteboard — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.

# ── PeerJS Self-Hosted Signaling Server (Phase 1) ────────────
# URL of your Railway-deployed PeerJS server.
# If not set, falls back to the PeerJS public cloud server.
VITE_PEER_SERVER_URL=https://your-peer-server.up.railway.app

# ── Supabase Room Persistence (Phase 2) ──────────────────────
# Get these from: https://app.supabase.com → Settings → API
# If not set, room persistence is disabled (drawing still works).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
